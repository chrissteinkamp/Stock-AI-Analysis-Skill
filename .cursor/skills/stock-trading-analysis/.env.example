# Optional API keys for stock-trading-analysis skill
# Copy to .env and load in your shell, or set as environment variables.
# Yahoo Finance and CoinGecko work WITHOUT any keys.

# Finnhub — real-time quote cross-check (free: finnhub.io)
# FINNHUB_API_KEY=your_key_here

# Alpha Vantage — reserved for future fundamentals (free: alphavantage.co)
# ALPHAVANTAGE_API_KEY=your_key_here
